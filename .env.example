# Siwu Agent -- Environment Variables (for API key injection)
# Copy this file to .env and fill in your keys.
# env vars take precedence over config.toml.

# --- LLM API Keys ---
SIWU_LLM_API_KEY="sk-your-key-here"
# SIWU_LLM_BASE_URL="https://api.deepseek.com"
# SIWU_LLM_MODEL="deepseek-v4-pro"

# Legacy compat (still works)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Anthropic Claude (set provider="anthropic" in config.toml)
ANTHROPIC_API_KEY=

# Tavily search (optional, web search disabled if empty)
TAVILY_API_KEY=
